# 실행 환경 설정: development, staging, production 등
TDEVELOPER_ENV=development

# AWS 설정
AWS_REGION=us-east-1
DYNAMODB_TABLE_PREFIX=TDeveloper-
S3_BUCKET_NAME=t-developer-context

# AWS Lambda 설정
LAMBDA_FUNCTION_NAME=t-developer-api
LAMBDA_ROLE_ARN=arn:aws:iam::123456789012:role/lambda-role

# GitHub 연동 설정 (토큰 및 저장소 정보)
GITHUB_TOKEN=your_github_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repository_name
GITHUB_BRANCH_PREFIX=feature/

# PR 자동 병합 설정 (true/false)
AUTO_MERGE=true

# Slack 연동 설정 (토큰 및 채널, 서명 시크릿)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#your-slack-channel
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Agno/AI 설정 (필요시에만 설정)
AGNO_API_KEY=your_agno_api_key
OPENAI_API_KEY=your_openai_api_key

# Q Developer 작업공간 경로
Q_DEVELOPER_WORKSPACE=./workspace/target_repos

# 알림 상세 수준 (minimal / normal / verbose)
NOTIFICATION_LEVEL=normal

# 애플리케이션 서버 네트워킹
HOST=0.0.0.0
PORT=8000

# JWT 설정
JWT_SECRET=your_jwt_secret_key

# 테스트 설정
MAX_RETRIES=3

# Lambda 기능 설정 (v1.0에서는 비활성화)
USE_LAMBDA_NOTIFIER=false
USE_LAMBDA_TEST_EXECUTOR=false
USE_LAMBDA_CODE_GENERATOR=false