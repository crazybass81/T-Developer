# 실행 환경 설정: development, staging, production 등
TDEVELOPER_ENV=development  # development, production

# AWS 설정
AWS_REGION=us-east-1  # AWS 서비스가 프로비저닝될 리전
DYNAMODB_TABLE_PREFIX=TDeveloper-  # 작업 컨텍스트 저장용 테이블 접두사
S3_BUCKET_NAME=t-developer-context  # 계획, 로그 등 아티팩트 저장 버킷

# GitHub 연동 설정 (토큰 및 저장소 정보)
GITHUB_TOKEN=your_github_token  # GitHub API 호출용 Personal Access Token (필수)
GITHUB_OWNER=crazybass81  # 대상 GitHub 저장소 소유자 이름 (필수)
GITHUB_REPO=T-Developer  # 대상 GitHub 저장소 이름 (필수)
GITHUB_BRANCH_PREFIX=feature/  # 작업 브랜치 이름 접두사

# Slack 연동 설정 (토큰 및 채널, 서명 시크릿)
SLACK_BOT_TOKEN=your_slack_bot_token  # Slack Bot User OAuth 토큰 (필수)
SLACK_CHANNEL=#t-developer  # 알림을 전송할 대상 채널
SLACK_SIGNING_SECRET=your_slack_signing_secret  # Slack 이벤트 요청 검증용 시크릿 (필수)

# AI 모델 설정
AGNO_API_KEY=your_agno_api_key  # Agno 플랫폼 API 키 (실제 AI 연동 시 필요)
OPENAI_API_KEY=your_openai_api_key  # OpenAI API 키 (실제 AI 연동 시 필요)

# JWT 설정
JWT_SECRET=your_jwt_secret_key  # JWT 토큰 생성/검증용 시크릿 키

# Q Developer 설정
Q_DEVELOPER_WORKSPACE=/tmp/q-workspace  # 코드 구현 작업을 위한 로컬 작업 공간 경로

# 작업 설정
NOTIFICATION_LEVEL=normal  # Slack 알림 상세 수준 (minimal, normal, verbose)

# 애플리케이션 서버 네트워킹
HOST=0.0.0.0  # FastAPI/Uvicorn이 바인딩할 호스트 주소
PORT=8000  # Uvicorn이 수신할 포트

# 참고: AWS 자격증명(AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)은
# .aws/credentials 설정이나 환경변수로 별도 구성 필요