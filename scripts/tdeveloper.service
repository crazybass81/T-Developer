[Unit]
Description=T-Developer FastAPI Service
After=network.target

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/T-Developer
EnvironmentFile=/home/ec2-user/T-Developer/.env
ExecStart=/home/ec2-user/T-Developer/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target