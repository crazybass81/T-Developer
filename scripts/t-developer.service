[Unit]
Description=T-Developer Backend Service
After=network.target

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/T-Developer
Environment="PATH=/home/ec2-user/T-Developer/venv/bin"
ExecStart=/home/ec2-user/T-Developer/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 4
Restart=always
RestartSec=5
StartLimitInterval=0

[Install]
WantedBy=multi-user.target